# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# Dependencies
node_modules/
.pnp
.pnp.js

# Testing
coverage/
test-results/
junit.xml
.jest-cache
e2e-report/
e2e-results*.xml
playwright-report/

# Production builds
build/
dist/

# Security - sensitive files
cloudflare-env.txt
.env
.env.*
!.env.example
!.env.test.example

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
lerna-debug.log*

# Editor & IDE
.idea
.vscode
*.swp
*.swo

# OS
.DS_Store
Thumbs.db

# Temporary files
*.tmp
*.temp
*.backup
*.bak

# Image files (except public assets)
*.png
*.jpg
*.jpeg
*.gif
!frontend/webapp/public/*.png
!frontend/webapp/public/*.ico

# ============================================
# Frontend: generated/temp files in webapp root
# ============================================
frontend/webapp/build/
frontend/webapp/coverage/
frontend/webapp/coverage-services/
frontend/webapp/.env*
frontend/webapp/test-results/
frontend/webapp/test-screenshots/
frontend/webapp/test-results-production/
frontend/webapp/test-deploy/
frontend/webapp/images/
frontend/webapp/tmp/
frontend/webapp-build/

# Frontend: temp JS/data files (analysis, debug, screenshots)
frontend/webapp/*.js
!frontend/webapp/postcss.config.js
!frontend/webapp/tailwind.config.js
!frontend/webapp/vite.config.js

# Frontend: temp report/output files (keep only essential configs)
frontend/webapp/*.md
frontend/webapp/*.xml
frontend/webapp/*.json
frontend/webapp/*.yaml
frontend/webapp/*.txt
!frontend/webapp/package.json
!frontend/webapp/README.md
!frontend/webapp/CLAUDE.md

# Frontend: temp screenshot/analysis folders
frontend/webapp/*-screenshots/
frontend/webapp/*-analysis*/
frontend/webapp/*-results*/
frontend/webapp/playwright-report-production/
frontend/webapp/emergency-build/
frontend/webapp/emergency-deploy/
frontend/webapp/build-backup-*/

# E2E tests (canonical location: frontend/webapp/e2e/)
frontend/webapp/e2e/*.spec.js
!frontend/webapp/e2e/tests/core-flows.spec.ts
!frontend/webapp/e2e/tests/visual-regression.spec.ts
!frontend/webapp/e2e/tests/visual-regression.spec.ts-snapshots/
!frontend/webapp/playwright.config.ts
frontend/webapp/e2e/.auth/

# ============================================
# Backend specific
# ============================================
backend/node_modules/
backend/dist/
backend/.env*
!backend/.env.example
backend/.serverless/
backend/deploy.log
backend/dynamodb-local/
backend/dynamodb-local-metadata.json
backend/package-lock.json

# ============================================
# Build & deploy artifacts
# ============================================
node_modules_backup_*/
**/node_modules_backup_*/
node_modules_old/
build-backup-*/
emergency-build/
emergency-deploy/
auto-deploy.sh
deploy-script.sh
force-build.js

# ============================================
# IDE and tool files
# ============================================
.claude/*
!.claude/commands/
.mcp.json
.serena/
.wrangler/
frontend/webapp/.wrangler/
frontend/webapp/.claude/
Claude-Code-Communication/

# Hosting (legacy, no longer used)
.netlify

# ============================================
# Documents - generated/sensitive
# ============================================
docs/ai_coding_principles.yaml
/docs/message/
/frontend/webapp/document/message/
/backend/document/message/

# ============================================
# Misc generated files
# ============================================
custom-reporter.js
test-data/
scripts/deployment/*.log
