{
  "name": "portfolio-wise",
  "version": "1.0.0",
  "private": true,
  "description": "PortfolioWise - 投資ポートフォリオ管理アプリケーション",
  "main": "src/index.tsx",
  "homepage": "/",
  "sideEffects": [
    "src/tokens/**/*.ts",
    "src/i18n/**/*.ts",
    "src/i18n/**/*.json"
  ],
  "dependencies": {
    "@headlessui/react": "^1.7.15",
    "@react-oauth/google": "^0.12.2",
    "@stripe/stripe-js": "^2.4.0",
    "@tanstack/react-query": "^5.90.21",
    "@testing-library/jest-dom": "5.16.5",
    "@testing-library/react": "13.4.0",
    "@testing-library/user-event": "13.5.0",
    "ajv": "^8.17.1",
    "axios": "^1.3.5",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "dayjs": "^1.11.7",
    "i18next": "^25.2.1",
    "i18next-browser-languagedetector": "^8.1.0",
    "i18next-http-backend": "^3.0.2",
    "jwt-decode": "^3.1.2",
    "lodash": "^4.17.21",
    "lucide-react": "^0.577.0",
    "papaparse": "^5.4.1",
    "react": "18.2.0",
    "react-dom": "18.2.0",
    "react-helmet-async": "^3.0.0",
    "react-i18next": "^15.5.2",
    "react-router-dom": "^6.10.0",
    "recharts": "^2.5.0",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^3.3.1",
    "vite-plugin-pwa": "^1.2.0",
    "zustand": "^5.0.11"
  },
  "scripts": {
    "start": "vite",
    "prebuild": "node scripts/generate-sitemap.js",
    "build": "vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:view-coverage": "open coverage/lcov-report/index.html || xdg-open coverage/lcov-report/index.html || start coverage/lcov-report/index.html",
    "test:clean": "rimraf coverage test-results",
    "typecheck": "tsc --noEmit",
    "health-check": "node scripts/health-check.js",
    "check-backend": "npm run health-check"
  },
  "eslintConfig": {
    "rules": {
      "no-console": [
        "warn",
        {
          "allow": [
            "warn",
            "error"
          ]
        }
      ],
      "no-unused-vars": "warn"
    }
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "devDependencies": {
    "@types/node": "^25.3.3",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.4",
    "@vitest/coverage-v8": "^4.0.18",
    "autoprefixer": "^10.4.14",
    "cheerio": "^1.0.0",
    "cross-env": "^7.0.3",
    "eslint-plugin-jsx-a11y": "^6.7.1",
    "jsdom": "^26.1.0",
    "msw": "^1.3.3",
    "postcss": "^8.4.21",
    "prettier": "^2.8.7",
    "readline-sync": "^1.4.10",
    "rimraf": "^3.0.2",
    "typescript": "^5.9.3",
    "vite": "^7.3.1",
    "vitest": "^4.0.18"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=8.0.0"
  },
  "keywords": [
    "portfolio",
    "management",
    "react",
    "testing",
    "coverage",
    "visualization"
  ],
  "author": "Portfolio Manager Team",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/portfolio-manager/portfolio-manager.git"
  },
  "bugs": {
    "url": "https://github.com/portfolio-manager/portfolio-manager/issues"
  }
}
