# Build configuration
SKIP_PREFLIGHT_CHECK=true

# API configuration (set these in your deployment platform)
# REACT_APP_API_BASE_URL=https://your-api-url.com
# REACT_APP_DEFAULT_EXCHANGE_RATE=150.0

# Google Analytics (GA4) — production only
# VITE_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# Sentry error monitoring — production only
# VITE_SENTRY_DSN=https://your-dsn@o0.ingest.sentry.io/0
# VITE_APP_VERSION=1.0.0

# Sentry source map upload (CI/CD only, not needed for local dev)
# SENTRY_AUTH_TOKEN=your-sentry-auth-token
# SENTRY_ORG=your-sentry-org
# SENTRY_PROJECT=your-sentry-project